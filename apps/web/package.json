{
  "name": "@agent-kanban/web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "prebuild": "pnpm --filter @agent-kanban/shared build && pnpm --filter agent-kanban build && mkdir -p public/cli && cp ../../packages/cli/dist/standalone.js public/cli/ak-standalone.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build && npx wrangler deploy",
    "db:migrate": "npx wrangler d1 migrations apply agent-kanban-db --local",
    "db:reset": "rm -rf .wrangler/state && pnpm db:migrate",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@agent-kanban/shared": "workspace:*",
    "@any-managed-agents/sdk": "github:saltbo/any-managed-agents#7c7b7fd2eb4d73b5b5182065ff8e61743802a91e&path:sdk/typescript",
